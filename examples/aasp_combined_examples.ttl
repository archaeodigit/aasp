@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ns1: <https://w3id.org/aasp/> .
@prefix ns2: <https://example.org/pkap-demo/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/controlled-scenario/CitationInheritanceRelation> a ns1:ClaimRelation ;
    ns1:fromClaim <https://example.org/controlled-scenario/InheritedClaim2015> ;
    ns1:relationBasis ns1:CitationInheritance ;
    ns1:relationReason "The catalogue repeats the interpretation without introducing new archaeological evidence."@en ;
    ns1:relationType ns1:Restatement ;
    ns1:toClaim <https://example.org/controlled-scenario/Claim2010> .

<https://example.org/controlled-scenario/ConfirmationRelation> a ns1:ClaimRelation ;
    ns1:fromClaim <https://example.org/controlled-scenario/ConfirmingClaim2012> ;
    ns1:relationBasis ns1:IndependentObservation ;
    ns1:relationReason "The 2012 revisit produces independent observations consistent with the 2010 chronology."@en ;
    ns1:relationType ns1:Confirmation ;
    ns1:toClaim <https://example.org/controlled-scenario/Claim2010> .

<https://example.org/controlled-scenario/GNSS2020> a ns1:ObservationActivity ;
    rdfs:label "2020 fictional GNSS reassessment"@en ;
    prov:generated <https://example.org/controlled-scenario/CorrectedPolygonGeometry> ;
    ns1:investigatedResource <https://example.org/controlled-scenario/FictionalLocality> .

<https://example.org/controlled-scenario/QualificationRelation> a ns1:ClaimRelation ;
    ns1:fromClaim <https://example.org/controlled-scenario/ReassessedClaim2020> ;
    ns1:relationBasis ns1:IndependentReassessment ;
    ns1:relationReason "Reassessment of diagnostic evidence narrows the earlier chronology without deleting the earlier published claim."@en ;
    ns1:relationType ns1:Qualification ;
    ns1:toClaim <https://example.org/controlled-scenario/Claim2010> .

<https://example.org/controlled-scenario/QuestioningRelation> a ns1:ClaimRelation ;
    ns1:fromClaim <https://example.org/controlled-scenario/QuestioningClaim2018> ;
    ns1:relationBasis ns1:IndependentReassessment ;
    ns1:relationReason "The 2018 review identifies that the published chronology is broader than the diagnostic evidence warrants."@en ;
    ns1:relationType ns1:Questioning ;
    ns1:toClaim <https://example.org/controlled-scenario/Claim2010> .

<https://example.org/controlled-scenario/Release20> a ns1:DatasetRelease ;
    rdfs:label "Fictional release 2.0"@en ;
    dcterms:hasVersion "2.0" ;
    prov:wasRevisionOf <https://example.org/controlled-scenario/Release11> ;
    ns1:publishesClaim <https://example.org/controlled-scenario/ReassessedClaim2020> ;
    ns1:revisionType ns1:ScholarlyRevision ;
    ns1:serializesDataset <https://example.org/controlled-scenario/DatasetSnapshot20> ;
    ns1:testsRequirement ns1:R6PublicationAndRevision .

<https://example.org/controlled-scenario/SpatialSupersessionRelation> a ns1:ClaimRelation ;
    ns1:fromClaim <https://example.org/controlled-scenario/PolygonClaim2020> ;
    ns1:relationBasis ns1:SpatialReassessment ;
    ns1:relationReason "The corrected polygon supersedes the legacy point for spatial analysis but does not by itself revise chronology."@en ;
    ns1:relationType ns1:Supersession ;
    ns1:toClaim <https://example.org/controlled-scenario/PointClaim2010> .

<https://example.org/controlled-scenario/SynthesisQualificationRelation> a ns1:ClaimRelation ;
    ns1:fromClaim <https://example.org/controlled-scenario/RevisedSynthesisState> ;
    ns1:relationBasis ns1:EvidentialExpansion ;
    ns1:relationReason "The same reusable plan is executed over a later knowledge state containing new diagnostic evidence and a reassessed claim."@en ;
    ns1:relationType ns1:Qualification ;
    ns1:testsRequirement ns1:R2ClaimLineage,
        ns1:R5SynthesisComparison ;
    ns1:toClaim <https://example.org/controlled-scenario/InitialSynthesisState> .

<https://example.org/controlled-scenario/scenario> a ns1:ControlledScenario ;
    rdfs:label "Controlled longitudinal revisability scenario"@en ;
    dcterms:description "A boundary test for claim lineage, repeated execution of a reusable plan, spatial reassessment, and the distinction between technical republication and scholarly revision. It is not empirical validation."@en ;
    ns1:isSyntheticScenario true .

<https://example.org/ekas-demo/EvidentialQualificationRelation> a ns1:ClaimRelation ;
    ns1:fromClaim <https://example.org/ekas-demo/SpecificLOCAAssertion> ;
    ns1:relationBasis ns1:EvidentialExpansion ;
    ns1:relationReason "A broader and more granular evidence state supports a more specific synthesis while the earlier synthesis remains citable."@en ;
    ns1:relationType ns1:Qualification ;
    ns1:testsRequirement ns1:R2ClaimLineage,
        ns1:R5SynthesisComparison ;
    ns1:toClaim <https://example.org/ekas-demo/InitialConcentrationAssertion> .

<https://example.org/ekas-demo/KesimiaContext> a ns1:SurveyContext ;
    rdfs:label "Kesimia survey context"@en ;
    ns1:isSourceDerived true .

<https://example.org/ekas-demo/graph> a ns1:ModifiedDemonstrationGraph ;
    rdfs:label "EKAS evidential-revisability demonstration"@en ;
    ns1:isArticleCreated true ;
    ns1:modificationNote "The graph coordinates published EKAS identifiers and documented relations through article-created evidence summaries, analytical views, executions, decisions, and synthesis assertions. It does not claim that EKAS originally used AASP."@en .

<https://example.org/ekas-demo/historicalAssociation> a ns1:DocumentedAssociation ;
    rdfs:label "Published association between LOCA 9003 and six Discovery Units"@en ;
    dcterms:source "Gregory, Pullen, and Tartaron 2001" ;
    ns1:associatesResource <https://example.org/ekas-demo/DU1529>,
        <https://example.org/ekas-demo/DU1530>,
        <https://example.org/ekas-demo/DU1531>,
        <https://example.org/ekas-demo/DU1542>,
        <https://example.org/ekas-demo/DU1543>,
        <https://example.org/ekas-demo/DU1544>,
        <https://example.org/ekas-demo/LOCA9003> ;
    ns1:isSourceDerived true .

ns2:Unit501ProceduralRelation a ns1:ClaimRelation ;
    ns1:fromClaim ns2:ExperimentalChronotypeAssertion501 ;
    ns1:relationBasis ns1:ProceduralReconfiguration ;
    ns1:relationReason "The two assertions describe the same survey unit through evidence states generated by different collection procedures; the difference is procedural rather than a silent correction of a source record."@en ;
    ns1:relationType ns1:AlternativeCharacterisation ;
    ns1:testsRequirement ns1:R2ClaimLineage,
        ns1:R5SynthesisComparison ;
    ns1:toClaim ns2:StandardChronotypeAssertion501 .

ns2:aggregateWeightGrams a rdf:Property ;
    rdfs:label "aggregate weight in grams"@en .

ns2:distinctChronotypeLabelCount a rdf:Property ;
    rdfs:label "distinct chronotype-label count"@en .

ns2:distinctPeriodLabelCount a rdf:Property ;
    rdfs:label "distinct period-label count"@en .

ns2:graph a ns1:ModifiedDemonstrationGraph ;
    rdfs:label "PKAP procedural-revisability demonstration"@en ;
    ns1:isArticleCreated true ;
    ns1:modificationNote "The graph coordinates source-derived PKAP records and CSV distinctions through article-created procedure representations, evidence states, analytical views, executions, decisions, assertions, and claim relations. It does not claim that PKAP originally used AASP."@en .

<https://opencontext.org/projects/bc71c724-eb1e-47d6-9d45-b586ddafdcfe> a ns1:ArchaeologicalProject ;
    rdfs:label "Eastern Korinthia Archaeological Survey"@en ;
    ns1:isSourceDerived true .

<https://example.org/controlled-scenario/ConfirmingClaim2012> a ns1:ChronologyClaim,
        ns1:PublishedClaim ;
    rdfs:label "2012 claim independently supports Late Roman occupation"@en ;
    ns1:aboutResource <https://example.org/controlled-scenario/FictionalLocality> ;
    ns1:isSyntheticScenario true ;
    ns1:supportedBy <https://example.org/controlled-scenario/RevisitEvidence2012> .

<https://example.org/controlled-scenario/DatasetSnapshot10> a dcat:Dataset ;
    rdfs:label "Fictional dataset snapshot 1.0"@en .

<https://example.org/controlled-scenario/DatasetSnapshot11> a dcat:Dataset ;
    rdfs:label "Fictional dataset snapshot 1.1"@en .

<https://example.org/controlled-scenario/DatasetSnapshot20> a dcat:Dataset ;
    rdfs:label "Fictional dataset snapshot 2.0"@en .

<https://example.org/controlled-scenario/IncludeClaim2010> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/controlled-scenario/ChronologyCriterion> ;
    ns1:selectionReason "The source-qualified 2010 chronology is the published claim available to the initial execution."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/controlled-scenario/Claim2010> .

<https://example.org/controlled-scenario/IncludeDiagnostic2020> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/controlled-scenario/ChronologyCriterion> ;
    ns1:selectionReason "The new diagnostic evidence is available in the revised release."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/controlled-scenario/DiagnosticEvidence2020> .

<https://example.org/controlled-scenario/IncludeEvidence2010> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/controlled-scenario/ChronologyCriterion> ;
    ns1:selectionReason "This is the evidence state available to the initial synthesis execution."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/controlled-scenario/CeramicEvidence2010> .

<https://example.org/controlled-scenario/IncludeEvidence2010Revised> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/controlled-scenario/ChronologyCriterion> ;
    ns1:selectionReason "The earlier evidence remains part of the revised knowledge state."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/controlled-scenario/CeramicEvidence2010> .

<https://example.org/controlled-scenario/IncludeReassessedClaim2020> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/controlled-scenario/ChronologyCriterion> ;
    ns1:selectionReason "The reassessed source-qualified chronology is included in the revised execution."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/controlled-scenario/ReassessedClaim2020> .

<https://example.org/controlled-scenario/InheritedClaim2015> a ns1:ChronologyClaim,
        ns1:PublishedClaim ;
    rdfs:label "2015 catalogue claim repeats Late Roman occupation"@en ;
    ns1:aboutResource <https://example.org/controlled-scenario/FictionalLocality> ;
    ns1:isSyntheticScenario true ;
    ns1:supportedBy <https://example.org/controlled-scenario/CeramicEvidence2010> .

<https://example.org/controlled-scenario/InitialAnalysisAssociation> a prov:Association ;
    prov:hadPlan <https://example.org/controlled-scenario/ReusableChronologyView> .

<https://example.org/controlled-scenario/InitialSynthesisExecution> a ns1:AnalysisExecution ;
    rdfs:label "Initial chronology synthesis execution"@en ;
    prov:generated <https://example.org/controlled-scenario/InitialSynthesisState> ;
    prov:qualifiedAssociation <https://example.org/controlled-scenario/InitialAnalysisAssociation> ;
    prov:used <https://example.org/controlled-scenario/CeramicEvidence2010>,
        <https://example.org/controlled-scenario/Claim2010> ;
    ns1:recordsSelectionDecision <https://example.org/controlled-scenario/IncludeClaim2010>,
        <https://example.org/controlled-scenario/IncludeEvidence2010> .

<https://example.org/controlled-scenario/LegacyPointGeometry> a geo:Geometry ;
    rdfs:label "Legacy point geometry"@en .

<https://example.org/controlled-scenario/PointClaim2010> a ns1:SpatialAssertion ;
    rdfs:label "2010 spatial assertion based on a legacy point"@en ;
    ns1:aboutResource <https://example.org/controlled-scenario/FictionalLocality> ;
    ns1:assertsGeometry <https://example.org/controlled-scenario/LegacyPointGeometry> ;
    ns1:supportedBy <https://example.org/controlled-scenario/CeramicEvidence2010> .

<https://example.org/controlled-scenario/PolygonClaim2020> a ns1:SpatialAssertion ;
    rdfs:label "2020 spatial assertion based on a corrected polygon"@en ;
    ns1:aboutResource <https://example.org/controlled-scenario/FictionalLocality> ;
    ns1:assertsGeometry <https://example.org/controlled-scenario/CorrectedPolygonGeometry> ;
    ns1:supportedBy <https://example.org/controlled-scenario/DiagnosticEvidence2020> .

<https://example.org/controlled-scenario/QuestioningClaim2018> a ns1:ChronologyClaim,
        ns1:PublishedClaim ;
    rdfs:label "2018 review questions the precision of the broad Late Roman label"@en ;
    ns1:aboutResource <https://example.org/controlled-scenario/FictionalLocality> ;
    ns1:isSyntheticScenario true ;
    ns1:supportedBy <https://example.org/controlled-scenario/CeramicEvidence2010> .

<https://example.org/controlled-scenario/Reassessment2020> a ns1:ReassessmentActivity ;
    rdfs:label "2020 fictional ceramic reassessment"@en ;
    prov:generated <https://example.org/controlled-scenario/DiagnosticEvidence2020> ;
    prov:used <https://example.org/controlled-scenario/CeramicEvidence2010> ;
    ns1:isSyntheticScenario true .

<https://example.org/controlled-scenario/Release11> a ns1:DatasetRelease ;
    rdfs:label "Fictional release 1.1"@en ;
    dcterms:hasVersion "1.1" ;
    prov:wasRevisionOf <https://example.org/controlled-scenario/DatasetSnapshot10> ;
    ns1:republishesUnchangedClaim <https://example.org/controlled-scenario/Claim2010> ;
    ns1:revisionType ns1:TechnicalRepublication ;
    ns1:serializesDataset <https://example.org/controlled-scenario/DatasetSnapshot11> ;
    ns1:testsRequirement ns1:R6PublicationAndRevision .

<https://example.org/controlled-scenario/RevisedAnalysisAssociation> a prov:Association ;
    prov:hadPlan <https://example.org/controlled-scenario/ReusableChronologyView> .

<https://example.org/controlled-scenario/RevisedSynthesisExecution> a ns1:AnalysisExecution ;
    rdfs:label "Revised chronology synthesis execution"@en ;
    prov:generated <https://example.org/controlled-scenario/RevisedSynthesisState> ;
    prov:qualifiedAssociation <https://example.org/controlled-scenario/RevisedAnalysisAssociation> ;
    prov:used <https://example.org/controlled-scenario/CeramicEvidence2010>,
        <https://example.org/controlled-scenario/DiagnosticEvidence2020>,
        <https://example.org/controlled-scenario/ReassessedClaim2020> ;
    ns1:recordsSelectionDecision <https://example.org/controlled-scenario/IncludeDiagnostic2020>,
        <https://example.org/controlled-scenario/IncludeEvidence2010Revised>,
        <https://example.org/controlled-scenario/IncludeReassessedClaim2020> .

<https://example.org/controlled-scenario/Revisit2012> a ns1:ObservationActivity ;
    rdfs:label "2012 fictional revisit"@en ;
    prov:generated <https://example.org/controlled-scenario/RevisitEvidence2012> ;
    ns1:investigatedResource <https://example.org/controlled-scenario/FictionalLocality> ;
    ns1:isSyntheticScenario true .

<https://example.org/controlled-scenario/Survey2010> a ns1:CollectionActivity,
        ns1:ObservationActivity ;
    rdfs:label "2010 fictional survey"@en ;
    prov:generated <https://example.org/controlled-scenario/CeramicEvidence2010> ;
    ns1:investigatedResource <https://example.org/controlled-scenario/FictionalLocality> ;
    ns1:isSyntheticScenario true .

<https://example.org/ekas-demo/ExcludeIntensifiedEvidence> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/ekas-demo/InitialEvidenceCriterion> ;
    ns1:selectionReason "This evidence was produced by a later intensified investigation and is excluded from the initial-state execution."@en ;
    ns1:selectionStatus ns1:excluded ;
    ns1:selectionTarget <https://example.org/ekas-demo/IntensifiedGridEvidence> .

<https://example.org/ekas-demo/IncludeHistoricalClaim> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/ekas-demo/ExpandedEvidenceCriterion> ;
    ns1:selectionReason "The historical claim is retained as a source-qualified interpretive input rather than silently converted into observation."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/ekas-demo/HistoricalLOCAClaim> .

<https://example.org/ekas-demo/IncludeInitialEvidence> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/ekas-demo/InitialEvidenceCriterion> ;
    ns1:selectionReason "The execution represents the initial documented evidence state."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/ekas-demo/InitialDUEvidence> .

<https://example.org/ekas-demo/IncludeInitialEvidenceExpanded> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/ekas-demo/ExpandedEvidenceCriterion> ;
    ns1:selectionReason "The earlier evidence state remains part of the expanded evidential basis."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/ekas-demo/InitialDUEvidence> .

<https://example.org/ekas-demo/IncludeIntensifiedEvidence> a ns1:SelectionDecision ;
    ns1:basedOnCriterion <https://example.org/ekas-demo/ExpandedEvidenceCriterion> ;
    ns1:selectionReason "The intensified grid evidence is included to support a more specific synthesis."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget <https://example.org/ekas-demo/IntensifiedGridEvidence> .

<https://example.org/ekas-demo/InitialAssociation> a prov:Association ;
    prov:hadPlan <https://example.org/ekas-demo/InitialView> .

<https://example.org/ekas-demo/InitialExecution> a ns1:AnalysisExecution ;
    rdfs:label "Initial EKAS synthesis execution"@en ;
    prov:generated <https://example.org/ekas-demo/InitialConcentrationAssertion> ;
    prov:qualifiedAssociation <https://example.org/ekas-demo/InitialAssociation> ;
    prov:used <https://example.org/ekas-demo/InitialDUEvidence> ;
    ns1:recordsSelectionDecision <https://example.org/ekas-demo/ExcludeIntensifiedEvidence>,
        <https://example.org/ekas-demo/IncludeInitialEvidence> ;
    ns1:testsRequirement ns1:R3ExplicitSelection,
        ns1:R4PlanExecutionSeparation .

<https://example.org/ekas-demo/InitialSurveyDocumentation> a ns1:ObservationActivity ;
    rdfs:label "Aggregate representation of initial DU survey and documentation"@en ;
    prov:generated <https://example.org/ekas-demo/InitialDUEvidence> ;
    ns1:investigatedResource <https://example.org/ekas-demo/DU1529>,
        <https://example.org/ekas-demo/DU1530>,
        <https://example.org/ekas-demo/DU1531>,
        <https://example.org/ekas-demo/DU1542>,
        <https://example.org/ekas-demo/DU1543>,
        <https://example.org/ekas-demo/DU1544> ;
    ns1:isArticleCreated true .

<https://example.org/ekas-demo/InitialView> a ns1:AnalyticalView ;
    rdfs:label "Initial evidence view"@en ;
    ns1:declaresCriterion <https://example.org/ekas-demo/InitialEvidenceCriterion> ;
    ns1:hasPurpose "Generate a synthesis from the initial Discovery-Unit evidence state while keeping later intensified evidence outside this execution."@en ;
    ns1:testsRequirement ns1:R1EvidenceStatePreservation,
        ns1:R3ExplicitSelection,
        ns1:R4PlanExecutionSeparation .

<https://example.org/ekas-demo/IntensifiedAssociation> a prov:Association ;
    prov:hadPlan <https://example.org/ekas-demo/IntensifiedView> .

<https://example.org/ekas-demo/IntensifiedExecution> a ns1:AnalysisExecution ;
    rdfs:label "Expanded EKAS synthesis execution"@en ;
    prov:generated <https://example.org/ekas-demo/SpecificLOCAAssertion> ;
    prov:qualifiedAssociation <https://example.org/ekas-demo/IntensifiedAssociation> ;
    prov:used <https://example.org/ekas-demo/HistoricalLOCAClaim>,
        <https://example.org/ekas-demo/InitialDUEvidence>,
        <https://example.org/ekas-demo/IntensifiedGridEvidence> ;
    ns1:recordsSelectionDecision <https://example.org/ekas-demo/IncludeHistoricalClaim>,
        <https://example.org/ekas-demo/IncludeInitialEvidenceExpanded>,
        <https://example.org/ekas-demo/IncludeIntensifiedEvidence> ;
    ns1:testsRequirement ns1:R3ExplicitSelection,
        ns1:R4PlanExecutionSeparation .

<https://example.org/ekas-demo/IntensifiedGridInvestigation> a ns1:CollectionActivity,
        ns1:ObservationActivity ;
    rdfs:label "Aggregate representation of intensified gridded investigation in LOCA 9003"@en ;
    prov:generated <https://example.org/ekas-demo/IntensifiedGridEvidence> ;
    ns1:investigatedResource <https://example.org/ekas-demo/LOCA9003> ;
    ns1:isArticleCreated true .

<https://example.org/ekas-demo/IntensifiedView> a ns1:AnalyticalView ;
    rdfs:label "Expanded evidential view"@en ;
    ns1:declaresCriterion <https://example.org/ekas-demo/ExpandedEvidenceCriterion> ;
    ns1:hasPurpose "Generate a more specific synthesis using the expanded evidential basis without overwriting the initial state."@en ;
    ns1:testsRequirement ns1:R1EvidenceStatePreservation,
        ns1:R3ExplicitSelection,
        ns1:R4PlanExecutionSeparation .

ns2:ExperimentalCollection501 a ns1:CollectionActivity,
        <https://takin.solutions/ontologies/CRMsurv/U2_Survey_Collection_Activity> ;
    rdfs:label "Unit 501 experimental collection stream — article representation"@en ;
    prov:generated ns2:ExperimentalEvidence501 ;
    prov:qualifiedAssociation ns2:experimentalFieldAssociation501 ;
    prov:used ns2:csvSnapshot ;
    ns1:investigatedResource <http://opencontext.org/subjects/c3edbdc2-6b6b-4885-bea5-16f8e75b5881> ;
    ns1:isArticleCreated true .

ns2:ExperimentalCollectionProcedure a <http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure>,
        prov:Plan ;
    rdfs:label "PKAP experimental intensive collection procedure — article representation"@en ;
    dcterms:description "Procedure representation for batches marked Experimental Unit = true and associated with Unit 501."@en ;
    ns1:isArticleCreated true .

ns2:ExperimentalEvidenceAnalysis501 a ns1:AnalysisExecution ;
    rdfs:label "Analysis execution over Unit 501 experimental evidence"@en ;
    prov:generated ns2:ExperimentalChronotypeAssertion501 ;
    prov:qualifiedAssociation ns2:experimentalAnalysisAssociation501 ;
    prov:used ns2:ExperimentalEvidence501 ;
    ns1:recordsSelectionDecision ns2:IncludeExperimentalEvidence501 .

ns2:IncludeExperimentalEvidence501 a ns1:SelectionDecision ;
    ns1:basedOnCriterion ns2:ChronotypeLabelComparisonCriterion ;
    ns1:selectionReason "Included as the evidence state generated by batches explicitly marked Experimental Unit = true for Unit 501."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget ns2:ExperimentalEvidence501 .

ns2:IncludeStandardEvidence501 a ns1:SelectionDecision ;
    ns1:basedOnCriterion ns2:ChronotypeLabelComparisonCriterion ;
    ns1:selectionReason "Included as the evidence state generated by the standard collection stream for Unit 501."@en ;
    ns1:selectionStatus ns1:included ;
    ns1:selectionTarget ns2:StandardEvidence501 .

ns2:StandardCollection501 a ns1:CollectionActivity,
        <https://takin.solutions/ontologies/CRMsurv/U2_Survey_Collection_Activity> ;
    rdfs:label "Unit 501 standard collection stream — article representation"@en ;
    prov:generated ns2:StandardEvidence501 ;
    prov:qualifiedAssociation ns2:standardFieldAssociation501 ;
    prov:used ns2:csvSnapshot ;
    ns1:investigatedResource <http://opencontext.org/subjects/c3edbdc2-6b6b-4885-bea5-16f8e75b5881> ;
    ns1:isArticleCreated true .

ns2:StandardEvidenceAnalysis501 a ns1:AnalysisExecution ;
    rdfs:label "Analysis execution over Unit 501 standard evidence"@en ;
    prov:generated ns2:StandardChronotypeAssertion501 ;
    prov:qualifiedAssociation ns2:standardAnalysisAssociation501 ;
    prov:used ns2:StandardEvidence501 ;
    ns1:recordsSelectionDecision ns2:IncludeStandardEvidence501 .

ns2:StandardPedestrianProcedure a <http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure>,
        prov:Plan ;
    rdfs:label "PKAP standard pedestrian collection procedure — article representation"@en ;
    dcterms:description "Procedure representation for the standard collection stream associated with Unit 501."@en ;
    ns1:isArticleCreated true .

ns2:experimentalAnalysisAssociation501 a prov:Association ;
    prov:hadPlan ns2:Unit501ProcedureComparisonView .

ns2:experimentalFieldAssociation501 a prov:Association ;
    prov:hadPlan ns2:ExperimentalCollectionProcedure .

ns2:standardAnalysisAssociation501 a prov:Association ;
    prov:hadPlan ns2:Unit501ProcedureComparisonView .

ns2:standardFieldAssociation501 a prov:Association ;
    prov:hadPlan ns2:StandardPedestrianProcedure .

<https://opencontext.org/projects/3f6dcd13-a476-488e-ed10-47d25513fcb2> a ns1:ArchaeologicalProject ;
    rdfs:label "Pyla-Koutsopetria Archaeological Project I: Pedestrian Survey"@en ;
    ns1:isSourceDerived true .

<https://example.org/controlled-scenario/CorrectedPolygonGeometry> a geo:Geometry ;
    rdfs:label "Corrected polygon geometry"@en .

<https://example.org/controlled-scenario/InitialSynthesisState> a ns1:SynthesisAssertion ;
    rdfs:label "Initial synthesis state: Late Roman occupation"@en ;
    prov:wasGeneratedBy <https://example.org/controlled-scenario/InitialSynthesisExecution> ;
    ns1:aboutResource <https://example.org/controlled-scenario/FictionalLocality> ;
    ns1:supportedBy <https://example.org/controlled-scenario/CeramicEvidence2010> .

<https://example.org/controlled-scenario/ReusableChronologyView> a ns1:AnalyticalView ;
    rdfs:label "Reusable chronology synthesis view"@en ;
    ns1:declaresCriterion <https://example.org/controlled-scenario/ChronologyCriterion> ;
    ns1:hasPurpose "Generate a chronology synthesis from the evidence and claims available in a declared dataset state."@en ;
